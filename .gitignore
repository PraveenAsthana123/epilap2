# Dependencies (NEVER commit — hundreds of MB)
node_modules/
viewer/node_modules/

# Build output
viewer/dist/
dist/

# Large EEG signal binaries — fetch locally, don't commit (GitHub 100MB/file limit)
*.edf
*.bdf
*.fif
*.set
*.mat
data/siena-sample/**/*.edf
data/**/*.edf

# Env / secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.pyc
.pytest_cache/

# SQLite (rebuild via db/build_sqlite.py)
*.db

# OS / editor
.DS_Store
Thumbs.db
*.log

# Keep: docs/, viewer/src, synthetic CSVs, dataset metadata

# MLOps generated store (rebuild via mlops/run_mlops_demo.py)
mlops/store/

# Large real EEG recordings (rebuild via analysis/fetch_chbmit.py)
data/real/chbmit/*.edf
